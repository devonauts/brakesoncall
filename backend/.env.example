# Flask
FLASK_CONFIG=development
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-a-different-secret

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///brakes.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/brakesoncall

# Redis (for rate limiting in production)
# REDIS_URL=redis://localhost:6379/0

# Cloudflare Turnstile (CAPTCHA)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe Payments
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=brakesoncall@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
